# ARPM local environment example
# Copy to .env only if your launcher or deployment system loads dotenv files.
# Never commit real API keys or private runtime data.

PORT=5000
DEBUG=True
SECRET_KEY=change-this-local-secret

ARPM_RUNTIME_DIR=runtime/arpm-app
ARPM_MODEL_ROOT=assets/models

